# Copy to apps/mobile/.env and fill in. Use the SAME values as apps/web/.env
# (same Supabase project = shared accounts; same TMDB token).
#
# Expo only exposes vars prefixed with EXPO_PUBLIC_ to the app bundle.

# TMDB — https://www.themoviedb.org/settings/api
EXPO_PUBLIC_TMDB_API_KEY="Bearer YOUR_TMDB_TOKEN"
EXPO_PUBLIC_TMDB_API_URL="https://api.themoviedb.org/3"
EXPO_PUBLIC_TMDB_IMAGE_PATH="https://image.tmdb.org/t/p/"

# Supabase — https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="YOUR_ANON_KEY"
